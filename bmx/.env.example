# Core
SECRET_KEY=replace-with-strong-secret
DEBUG=false
ALLOWED_HOSTS=czechbmx.cz,www.czechbmx.cz
YOUR_DOMAIN=https://czechbmx.cz
CSRF_TRUSTED_ORIGINS=https://czechbmx.cz,https://www.czechbmx.cz

# Security
ENABLE_HTTPS_SECURITY=true
SECURE_SSL_REDIRECT=true
CSP_ENFORCE=true

# Cache / rate limits
REDIS_URL=redis://127.0.0.1:6379/1
# Set only for a deliberate single-process fallback where shared rate limits are not required.
ALLOW_LOCMEM_CACHE_IN_PRODUCTION=false

# Stripe
STRIPE_LIVE_MODE=true
STRIPE_LIVE_PUBLIC_KEY=pk_live_replace_me
STRIPE_LIVE_SECRET_KEY=sk_live_replace_me
STRIPE_LIVE_ENDPOINT_SECRET=whsec_replace_me

# Email
EMAIL_HOST=smtp.seznam.cz
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=true
DEFAULT_FROM_EMAIL=noreply@czechbmx.cz

# Observability
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.15
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_MAX_BREADCRUMBS=50
SENTRY_LOG_LEVEL=INFO
SENTRY_EVENT_LEVEL=ERROR
SENTRY_HEALTHCHECK_PATHS=/healthz,/readyz,/csp-report
LOG_AS_JSON=true

# Mobile API / CORS
# Čárkou oddělený seznam allowed origins pro mobilní app (Capacitor, Expo web, apod.)
# Nativní HTTP klienti (iOS/Android) to nepotřebují — jen WebView-based aplikace
CORS_ALLOWED_ORIGINS=https://app.czechbmx.cz

# Offsite záloha SQLite na Google Drive (přes rclone, viz docs/BACKUP.md)
# Prázdné = offsite upload se přeskočí.
OFFSITE_BACKUP_RCLONE_REMOTE=
OFFSITE_BACKUP_RETENTION_DAYS=30

# Optional
OPENAI_API_KEY=
