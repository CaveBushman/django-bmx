#, python-format
msgid "Ahoj %(name)s,"
msgstr "Ciao %(name)s,"

msgid "dokončete registraci účtu na Czech BMX kliknutím na tento odkaz:"
msgstr ""
"completare la registrazione dell'account BMX ceco facendo clic su questo "
"collegamento:"

msgid "Pokud jste registraci nevytvářeli, tento e-mail můžete ignorovat."
msgstr "Se non hai creato una registrazione, puoi ignorare questa email."

msgid "Aktivace účtu"
msgstr "Attivazione dell'account"

msgid "Zkontrolujte svůj e-mail"
msgstr "Controlla la tua email"

msgid ""
"Poslali jsme vám aktivační odkaz. Účet se zapne až po kliknutí na odkaz v "
"e-mailu."
msgstr ""
"Ti abbiamo inviato un link di attivazione. L'account verrà attivato solo "
"dopo aver cliccato sul collegamento contenuto nell'e-mail."

msgid "Další krok"
msgstr "Prossimo passo"

msgid ""
"Otevřete zprávu od Czech BMX a potvrďte registraci. Pokud e-mail nevidíte "
"během několika minut, zkontrolujte i složku spam nebo hromadné."
msgstr ""
"Apri il messaggio di Czech BMX e conferma la registrazione. Se non vedi "
"l'e-mail entro pochi minuti, controlla anche la cartella dello spam o della "
"posta indesiderata."

msgid ""
"Po aktivaci se budete moct přihlásit stejným e-mailem a heslem, které jste "
"právě zadali."
msgstr ""
"Dopo l'attivazione potrai accedere con la stessa email e password che hai "
"appena inserito."

msgid "E-mail nedorazil?"
msgstr "La mail non è arrivata?"

msgid "Můžete si nechat poslat nový aktivační odkaz na stejnou adresu."
msgstr "Puoi ricevere un nuovo link di attivazione allo stesso indirizzo."

msgid "Otevřít formulář pro nové odeslání"
