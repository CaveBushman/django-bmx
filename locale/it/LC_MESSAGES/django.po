#, python-format
msgid "Kolik je %(human_check_question)s?"
msgstr "Quanto vale %(human_check_question)s?"

msgid "Poslat nový odkaz"
msgstr "Invia un nuovo collegamento"

msgid "Přihlášení"
msgstr "Accedi"

msgid "Přístup do interní části webu"
msgstr "Accesso alla parte interna del sito web"

msgid ""
"Zadejte e-mail a heslo k účtu Czech BMX. Pokud ještě nejste registrováni,"
msgstr ""
"Inserisci l'e-mail e la password per l'account BMX ceco. Se non sei ancora "
"registrato,"

msgid "registrujte se zde"
msgstr "registrati qui"

msgid "Ještě vám nejde přihlášení?"
msgstr "Hai ancora problemi ad accedere?"

msgid ""
"Nový účet je potřeba nejdřív potvrdit přes aktivační odkaz v e-mailu. Pokud "
"formulář zachytí podezřelé chování, může se zobrazit krátké ověření proti "
"robotům."
msgstr ""
"Il nuovo account deve essere prima confermato tramite il link di attivazione"
" contenuto nell'e-mail. Se il modulo rileva un comportamento sospetto, "
"potrebbe apparire una breve convalida anti-bot."

msgid "Poslat aktivační e-mail znovu"
msgstr "Invia di nuovo l'e-mail di attivazione"

msgid "Zapomněli jste heslo?"
msgstr "Hai dimenticato la password?"

msgid ""
"Zobrazujeme ho jen po sérii neúspěšných nebo podezřelých pokusů o "
"přihlášení."
msgstr ""
"Lo mostriamo solo dopo una serie di tentativi di accesso falliti o sospetti."

msgid "Zapamatovat si mě"
msgstr "Ricordati di me"

msgid "Přihlášení zůstane aktivní po dobu 14 dní."
msgstr "Il login rimarrà attivo per 14 giorni."

msgid "Přihlásit se"
msgstr "Tronco d'albero"

msgid ""
"Vyplňte své základní údaje pro vytvoření účtu. Po odeslání formuláře vám "
"pošleme aktivační e-mail a účet se zapne až po jeho potvrzení. Pokud už účet"
" máte,"
msgstr ""
"Inserisci le tue informazioni di base per creare un account. Dopo aver "
"inviato il modulo, ti invieremo un'e-mail di attivazione e l'account verrà "
"attivato solo dopo la sua conferma. Se hai già un account,"

msgid "přihlaste se zde"
msgstr "accedi qui"

msgid ""
"Notice: user registration and credit purchases are intended for Czech riders"
" only."
msgstr ""
"Avviso: la registrazione dell'utente e l'acquisto di crediti sono destinati "
"esclusivamente ai ciclisti cechi."

msgid "Jak registrace funguje"
msgstr "Come funziona la registrazione"

msgid ""
"1. Vyplníte formulář. 2. Potvrdíte registraci v e-mailu. 3. Teprve potom se "
"můžete přihlásit a pracovat s kredity nebo registracemi jezdců."
msgstr ""
"1. Compila il modulo. 2. Confermi la registrazione nell'e-mail. 3. Solo "
"allora potrai accedere e lavorare con i crediti o le registrazioni dei "
"ciclisti."

msgid ""
"Po několika podezřelých pokusech chceme krátké potvrzení, že formulář "
"vyplňuje člověk."
msgstr ""
"Dopo alcuni tentativi sospetti, vogliamo una breve conferma che una persona "
"sta compilando il modulo."

msgid ""
"Na tento e-mail už čeká nedokončená registrace. Pošlete si nový aktivační "
"odkaz."
msgstr ""
"C'è già una registrazione incompleta in attesa di questa email. Inviati un "
"nuovo link di attivazione."

msgid "Uživatel s tímto e-mailem již existuje."
msgstr "Esiste già un utente con questa email."

msgid "Uživatel s tímto uživatelským jménem již existuje."
msgstr "Esiste già un utente con questo nome utente."

msgid ""
"Heslo není shodné s heslem pro kontrolu. Zadejte registrační údaje znovu"
msgstr ""
"La password non è la stessa della password di controllo. Inserisci "
"nuovamente i tuoi dati di registrazione"

msgid ""
"Pro tento e-mail existuje více historických účtů. Kontaktujte "
"administrátora."
msgstr ""
"Esistono più account storici per questa email. Contatta l'amministratore."

msgid ""
"Účet ještě není aktivovaný. Otevřete aktivační e-mail a potvrďte registraci."
" Pokud zprávu nevidíte, zkontrolujte i spam."
msgstr ""
"Conto non ancora attivato. Apri l'e-mail di attivazione e conferma la "
"registrazione. Se non vedi il messaggio, controlla lo spam."

msgid "Neplatné uživatelské jméno nebo heslo."
msgstr "Nome utente o password non validi."

msgid "Aktivační odkaz je neplatný."
msgstr "Il collegamento di attivazione non è valido."

msgid "Aktivační odkaz je neplatný nebo expiroval."
msgstr "Il collegamento di attivazione non è valido o è scaduto."

msgid "Aktivační odkaz expiroval. Zaregistrujte se prosím znovu."
msgstr ""
"Il collegamento di attivazione è scaduto. Si prega di registrarsi di nuovo."

msgid ""
"Účet byl úspěšně aktivován. Teď se můžete přihlásit svým e-mailem a heslem."
msgstr ""
"L'account è stato attivato con successo. Ora puoi accedere con la tua email "
"e password."

msgid ""
"Pokud pro tento e-mail existuje čekající registrace, poslali jsme nový "
"aktivační odkaz."
msgstr ""
"Se c'è una registrazione in sospeso per questa email, abbiamo inviato un "
"nuovo collegamento di attivazione."

