msgstr "Versenyzési trend"

msgid "Start závodu"
msgstr "A verseny kezdete"

msgid "Pro tuto statistiku není v současné době dostatek dat."
msgstr "Jelenleg nem áll rendelkezésre elegendő adat ehhez a statisztikához."

msgid "První zatáčka"
msgstr "Első kanyar"

msgid "Pro vybranou trať zatím nejsou uložené žádné detailní jízdy."
msgstr "A kiválasztott pályához még nincsenek elmentve részletes utazások."

msgid ""
"Vyber trať nebo klub nahoře a zobrazí se prémiové statistiky této dráhy."
msgstr ""
"Válasszon fent egy tanfolyamot vagy klubot, és megjelennek az adott kurzus "
"prémium statisztikái."

msgid "Pro tohoto jezdce zatím nejsou uložené žádné detailní časy z tratí."
msgstr "Ehhez a versenyzőhöz még nincsenek elmentve részletes pályaidők."

