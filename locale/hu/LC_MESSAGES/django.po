msgstr "Szia %(name)s!"

msgid "dokončete registraci účtu na Czech BMX kliknutím na tento odkaz:"
msgstr "fejezze be a cseh BMX számla regisztrációját erre a linkre kattintva:"

msgid "Pokud jste registraci nevytvářeli, tento e-mail můžete ignorovat."
msgstr ""
"Ha nem Ön hozott létre regisztrációt, figyelmen kívül hagyhatja ezt az "
"e-mailt."

msgid "Aktivace účtu"
msgstr "Fiók aktiválása"

